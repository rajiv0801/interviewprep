<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Receipt – Graphora</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            background-color: #0f0f0f;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 600px;
            margin: 40px auto;
            background-color: #1a1a1a;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #2a2a2a;
        }

        .header {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            padding: 40px;
            text-align: center;
        }

        .header h1 {
            margin: 0;
            color: #fff;
            font-size: 26px;
        }

        .header p {
            margin: 8px 0 0;
            color: rgba(255, 255, 255, 0.85);
            font-size: 15px;
        }

        .content {
            padding: 36px 32px;
            color: #e0e0e0;
        }

        .content h2 {
            color: #fff;
            margin-top: 0;
        }

        .amount-box {
            text-align: center;
            background: #242424;
            border-radius: 12px;
            padding: 28px;
            margin: 20px 0;
        }

        .amount-box .amount {
            font-size: 48px;
            font-weight: 900;
            color: #6366f1;
        }

        .amount-box .currency {
            font-size: 20px;
            color: #888;
        }

        .receipt-card {
            background: #242424;
            border-radius: 10px;
            padding: 20px 24px;
            margin: 20px 0;
        }

        .receipt-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #2e2e2e;
            font-size: 14px;
        }

        .receipt-row:last-child {
            border-bottom: none;
        }

        .receipt-label {
            color: #888;
        }

        .receipt-value {
            color: #e0e0e0;
            font-weight: 600;
            font-family: monospace;
        }

        .btn {
            display: block;
            width: fit-content;
            margin: 24px auto;
            padding: 14px 36px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: #fff;
            text-decoration: none;
            border-radius: 8px;
            font-weight: bold;
            font-size: 15px;
            text-align: center;
        }

        .footer {
            background: #111;
            padding: 20px;
            text-align: center;
            font-size: 12px;
            color: #555;
            border-top: 1px solid #222;
        }

        .footer a {
            color: #6366f1;
            text-decoration: none;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            <h1>🧾 Payment Receipt</h1>
            <p>Your payment has been processed successfully</p>
        </div>
        <div class="content">
            <h2>Hi {{studentName}},</h2>
            <p>Thank you for your payment! Here's your receipt for the mentorship session with
                <strong>{{mentorName}}</strong>.</p>

            <div class="amount-box">
                <div class="amount"><span class="currency">₹</span>{{amount}}</div>
                <div style="color: #888; font-size: 13px; margin-top: 8px;">Payment Successful</div>
            </div>

            <div class="receipt-card">
                <div class="receipt-row">
                    <span class="receipt-label">Booking ID</span>
                    <span class="receipt-value">{{bookingId}}</span>
                </div>
                <div class="receipt-row">
                    <span class="receipt-label">Payment ID</span>
                    <span class="receipt-value">{{razorpayPaymentId}}</span>
                </div>
                <div class="receipt-row">
                    <span class="receipt-label">Mentor</span>
                    <span class="receipt-value">{{mentorName}}</span>
                </div>
                <div class="receipt-row">
                    <span class="receipt-label">Session Date</span>
                    <span class="receipt-value">{{scheduledAt}}</span>
                </div>
                <div class="receipt-row">
                    <span class="receipt-label">Amount Paid</span>
                    <span class="receipt-value">{{currency}} {{amount}}</span>
                </div>
            </div>

            <a href="{{bookingUrl}}" class="btn">View Booking Details</a>

            <p style="font-size: 12px; color: #555; text-align: center;">Please save this receipt for your records.
                Refunds are subject to our cancellation policy.</p>
        </div>
        <div class="footer">
            <p>Need help? <a href="mailto:{{supportEmail}}">{{supportEmail}}</a></p>
            <p>© 2025 Graphora. All rights reserved.</p>
        </div>
    </div>
</body>

</html>